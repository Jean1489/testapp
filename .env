# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# Tags de las imágenes — estos son los que el Jenkinsfile actualizaría
FRONTEND_TAG=abc1234-2025-01-15-10-30-00-staging
BACKEND_TAG=abc1234-2025-01-15-10-30-00-staging

# Simula el namespace que Terraform crearía
NAMESPACE=staging
ENVIRONMENT=staging

# Simula los secrets que Terraform inyectaría en K8s
DB_HOST=db.staging.internal
SECRET_KEY=mi-secret-key-de-prueba
